<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#0a0a0a; color:#fff; font-family:'Segoe UI',sans-serif; min-height:100vh; }
    header { background:#111; border-bottom:1px solid #FA8112; padding:1rem 2rem;
             display:flex; justify-content:space-between; align-items:center; }
    header h1 { color:#FA8112; font-size:1.2rem; letter-spacing:2px; }
    header a { color:#aaa; text-decoration:none; font-size:.85rem; }
    header a:hover { color:#FA8112; }
    .main { padding:2rem; max-width:1100px; margin:0 auto; }
    h2 { color:#FA8112; margin-bottom:1.5rem; }
    .stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1rem; margin-bottom:2rem; }
    .stat-card { background:#111; border:1px solid #222; border-radius:10px; padding:1.5rem; text-align:center; }
    .stat-card .num { font-size:2.5rem; font-weight:700; color:#FA8112; }
    .stat-card .label { color:#888; margin-top:.3rem; font-size:.9rem; }
    .nav-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1rem; }
    .nav-card { background:#111; border:1px solid #333; border-radius:10px; padding:1.5rem;
                text-decoration:none; color:#fff; transition:.2s; display:block; }
    .nav-card:hover { border-color:#FA8112; background:#1a1a1a; }
    .nav-card h3 { color:#FA8112; margin-bottom:.5rem; }
    .nav-card p { color:#888; font-size:.85rem; }
  </style>
</head>
<body>
  <header>
    <h1>TRS ADMIN</h1>
    <div>
      <span style="color:#aaa;margin-right:1rem;">👤 <%= admin.username %></span>
      <a href="/admin/logout">Logout</a>
    </div>
  </header>
  <div class="main">
    <h2>Dashboard</h2>
    <div class="stats">
      <div class="stat-card"><div class="num"><%= courses %></div><div class="label">Courses</div></div>
      <div class="stat-card"><div class="num"><%= teachers %></div><div class="label">Teachers</div></div>
      <div class="stat-card"><div class="num"><%= gallery %></div><div class="label">Gallery Items</div></div>
    </div>
    <div class="nav-cards">
      <a class="nav-card" href="/admin/courses">
        <h3>Courses</h3>
        <p>Add, edit, or remove course cards from the website</p>
      </a>
      <a class="nav-card" href="/admin/teachers">
        <h3>Teachers</h3>
        <p>Manage teacher profiles and information</p>
      </a>
      <a class="nav-card" href="/admin/gallery">
        <h3>Student Gallery</h3>
        <p>Add or remove gallery photos</p>
      </a>
    </div>
  </div>
</body>
</html>
