<!DOCTYPE html><html lang="en"><head><%- include('partials/head',{title}) %></head>
<body>
<%- include('partials/sidebar',{page:'dashboard',admin}) %>
<div class="admin-main">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Welcome back, <%= admin.username %> — here's your studio at a glance.</p>
  </div>
  <div class="page-body">
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-num"><%= courses %></div><div class="stat-lbl">Courses</div></div>
      <div class="stat-card"><div class="stat-num"><%= teachers %></div><div class="stat-lbl">Teachers</div></div>
      <div class="stat-card"><div class="stat-num"><%= gallery %></div><div class="stat-lbl">Gallery Photos</div></div>
      <div class="stat-card" style="<%= enquiries > 0 ? 'border-color:rgba(255,98,0,0.4)' : '' %>">
        <div class="stat-num"><%= enquiries %></div>
        <div class="stat-lbl">Unread Enquiries</div>
      </div>
      <div class="stat-card" style="<%= leads > 0 ? 'border-color:rgba(37,211,102,0.45);background:rgba(37,211,102,0.04)' : '' %>">
        <div class="stat-num" style="<%= leads > 0 ? 'color:#25d366' : '' %>"><%= leads %></div>
        <div class="stat-lbl">🔥 Hot Leads</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem">
      <a href="/admin/courses" class="g-card" style="text-decoration:none">
        <div style="font-size:1.5rem;margin-bottom:.75rem">🎓</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:.3rem">Courses</div>
        <div style="color:var(--muted);font-size:.83rem">Add, edit or remove course cards</div>
      </a>
      <a href="/admin/teachers" class="g-card" style="text-decoration:none">
        <div style="font-size:1.5rem;margin-bottom:.75rem">👤</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:.3rem">Teachers</div>
        <div style="color:var(--muted);font-size:.83rem">Manage instructor profiles & photos</div>
      </a>
      <a href="/admin/gallery" class="g-card" style="text-decoration:none">
        <div style="font-size:1.5rem;margin-bottom:.75rem">🖼</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:.3rem">Gallery</div>
        <div style="color:var(--muted);font-size:.83rem">Upload or remove student photos</div>
      </a>
      <a href="/admin/enquiries" class="g-card" style="text-decoration:none;<%= leads > 0 ? 'border-color:rgba(37,211,102,0.4);' : enquiries > 0 ? 'border-color:rgba(255,98,0,0.4);' : '' %>">
        <div style="font-size:1.5rem;margin-bottom:.75rem">📩</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:.3rem">
          Enquiries
          <% if(leads > 0){ %>
          <span style="background:#25d366;color:#000;font-size:.65rem;padding:2px 8px;border-radius:50px;margin-left:.4rem;font-weight:800;vertical-align:middle"><i class="fa-brands fa-whatsapp"></i> <%= leads %> lead<%= leads>1?'s':'' %></span>
          <% } else if(enquiries > 0){ %>
          <span style="background:var(--orange);color:#000;font-size:.65rem;padding:2px 8px;border-radius:50px;margin-left:.4rem;font-weight:800;vertical-align:middle"><%= enquiries %> new</span>
          <% } %>
        </div>
        <div style="color:var(--muted);font-size:.83rem">View contact form submissions & leads</div>
      </a>
    </div>
  </div>
</div>
</body></html>
