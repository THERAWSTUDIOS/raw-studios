<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= title %></title>
<style>
:root{--bg:#080808;--surface:#0f0f0f;--card:rgba(255,255,255,0.03);--border:rgba(255,98,0,0.12);--orange:#FF6200;--gold:#FFB300;--red:#D93800;--text:#f0f0f0;--muted:#777;--radius:10px}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh;display:flex}

/* Sidebar */
.sidebar{width:220px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.sidebar-logo{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid var(--border)}
.sidebar-logo .brand{font-size:.7rem;letter-spacing:3px;color:var(--muted);text-transform:uppercase}
.sidebar-logo .name{font-size:1.1rem;font-weight:800;background:linear-gradient(135deg,var(--red),var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:1px;margin-top:.2rem}
.sidebar-nav{padding:1rem 0;flex:1}
.nav-item{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.25rem;color:var(--muted);text-decoration:none;font-size:.88rem;font-weight:500;transition:.2s;border-left:3px solid transparent}
.nav-item:hover{color:var(--text);background:rgba(255,98,0,0.06);border-left-color:rgba(255,98,0,0.3)}
.nav-item.active{color:var(--orange);background:rgba(255,98,0,0.08);border-left-color:var(--orange)}
.nav-item .icon{width:18px;text-align:center;font-size:.9rem}
.sidebar-footer{padding:1rem 1.25rem;border-top:1px solid var(--border)}
.admin-pill{display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem}
.admin-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--red),var(--orange));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:#fff;flex-shrink:0}
.admin-name{font-size:.82rem;color:var(--muted);font-weight:500}
.logout-btn{display:block;width:100%;padding:.55rem;background:rgba(192,57,43,0.12);border:1px solid rgba(192,57,43,0.25);color:#e74c3c;border-radius:var(--radius);font-size:.8rem;text-align:center;text-decoration:none;transition:.2s}
.logout-btn:hover{background:rgba(192,57,43,0.22)}

/* Main content */
.admin-main{flex:1;min-width:0;overflow-x:hidden}
.page-header{padding:1.75rem 2rem 0;border-bottom:1px solid var(--border);padding-bottom:1.25rem;margin-bottom:2rem}
.page-header h1{font-size:1.4rem;font-weight:700;background:linear-gradient(135deg,var(--text),var(--muted));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.page-header p{color:var(--muted);font-size:.85rem;margin-top:.25rem}
.page-body{padding:0 2rem 2rem}

/* Cards */
.g-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.5rem;transition:.2s}
.g-card:hover{border-color:rgba(255,98,0,0.25);background:rgba(255,98,0,0.02)}

/* Buttons */
.btn{padding:.55rem 1.1rem;border:none;border-radius:8px;cursor:pointer;font-size:.85rem;font-weight:600;transition:.2s;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem}
.btn-primary{background:linear-gradient(135deg,var(--red),var(--orange));color:#fff}
.btn-primary:hover{opacity:.9;transform:translateY(-1px)}
.btn-ghost{background:rgba(255,98,0,0.08);color:var(--orange);border:1px solid rgba(255,98,0,0.2)}
.btn-ghost:hover{background:rgba(255,98,0,0.15)}
.btn-danger{background:rgba(192,57,43,0.12);color:#e74c3c;border:1px solid rgba(192,57,43,0.25)}
.btn-danger:hover{background:rgba(192,57,43,0.22)}
.btn-sm{padding:.35rem .75rem;font-size:.78rem}

/* Form */
.field{margin-bottom:1.1rem}
.field label{display:block;color:var(--muted);font-size:.78rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:.45rem}
.field input,.field textarea,.field select{width:100%;padding:.7rem 1rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius);color:var(--text);font-size:.9rem;font-family:inherit;transition:.2s}
.field input:focus,.field textarea:focus,.field select:focus{outline:none;border-color:var(--orange);background:rgba(255,98,0,0.04)}
.field select option{background:#111}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem}

/* Modal */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(4px);z-index:500;align-items:center;justify-content:center;padding:1rem}
.modal-bg.open{display:flex}
.modal{background:#111;border:1px solid rgba(255,98,0,0.25);border-radius:18px;padding:2rem;width:100%;max-width:520px;max-height:92vh;overflow-y:auto}
.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem}
.modal-header h3{font-size:1.1rem;font-weight:700;background:linear-gradient(135deg,var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.modal-close{background:none;border:none;color:var(--muted);font-size:1.3rem;cursor:pointer;line-height:1;padding:.2rem}
.modal-close:hover{color:var(--text)}
.modal-footer{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--border)}

/* Tag chip editor */
.tags-editor{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius);padding:.5rem .75rem;display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;cursor:text;min-height:44px;transition:.2s}
.tags-editor:focus-within{border-color:var(--orange)}
.tag-chip{display:flex;align-items:center;gap:.3rem;background:rgba(255,98,0,0.12);border:1px solid rgba(255,98,0,0.3);color:var(--orange);border-radius:50px;padding:3px 10px 3px 12px;font-size:.76rem;font-weight:600}
.tag-chip button{background:none;border:none;color:var(--orange);cursor:pointer;font-size:.9rem;opacity:.7}
.tag-chip button:hover{opacity:1}
.tag-input{background:none;border:none;outline:none;color:var(--text);font-size:.85rem;min-width:80px;flex:1}

/* Drag drop */
.drop-zone{border:2px dashed rgba(255,255,255,0.1);border-radius:12px;padding:1.5rem;text-align:center;cursor:pointer;transition:.2s;position:relative}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--orange);background:rgba(255,98,0,0.04)}
.drop-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.drop-zone .dz-icon{font-size:2rem;margin-bottom:.5rem;opacity:.5}
.drop-zone .dz-text{color:var(--muted);font-size:.83rem}.drop-zone .dz-text span{color:var(--orange)}
.preview-wrap{margin-top:.75rem;display:none;align-items:center;gap:.75rem}
.preview-wrap.show{display:flex}
.preview-img{width:56px;height:56px;border-radius:8px;object-fit:cover;border:1px solid var(--border)}
.preview-name{color:var(--muted);font-size:.8rem;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.preview-remove{background:none;border:none;color:#e74c3c;cursor:pointer;font-size:1.1rem}
.progress-bar{height:2px;background:linear-gradient(90deg,var(--red),var(--orange),var(--gold));width:0;border-radius:2px;margin-top:.5rem;transition:width .3s}

/* Toast */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:linear-gradient(135deg,var(--red),var(--orange));color:#fff;padding:.75rem 1.25rem;border-radius:10px;font-weight:600;font-size:.87rem;display:none;z-index:9999;box-shadow:0 8px 24px rgba(255,98,0,0.3)}
.toast.show{display:block}

/* Stat cards */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.25rem;text-align:center;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--red),var(--orange),var(--gold))}
.stat-num{font-size:2rem;font-weight:800;background:linear-gradient(135deg,var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat-lbl{font-size:.78rem;color:var(--muted);margin-top:.2rem;text-transform:uppercase;letter-spacing:.5px}

/* Table */
.g-table{width:100%;border-collapse:collapse}
.g-table th{padding:.75rem 1rem;text-align:left;font-size:.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border)}
.g-table td{padding:.85rem 1rem;border-bottom:1px solid rgba(255,255,255,0.03);font-size:.87rem;vertical-align:middle}
.g-table tr:hover td{background:rgba(255,98,0,0.02)}
.g-table .td-actions{display:flex;gap:.4rem}

/* Gallery grid */
.gal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.75rem}
.gal-item{border-radius:10px;overflow:hidden;position:relative;aspect-ratio:1;background:var(--card);border:1px solid var(--border)}
.gal-item img{width:100%;height:100%;object-fit:cover;display:block}
.gal-item .del-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.65);display:flex;align-items:center;justify-content:center;opacity:0;transition:.2s}
.gal-item:hover .del-overlay{opacity:1}
.gal-add{border:2px dashed rgba(255,98,0,0.25);border-radius:10px;aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.4rem;cursor:pointer;position:relative;transition:.2s;background:rgba(255,98,0,0.02)}
.gal-add:hover{border-color:var(--orange);background:rgba(255,98,0,0.06)}
.gal-add input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.gal-add span{font-size:1.5rem;color:rgba(255,98,0,0.4)}
.gal-add p{font-size:.75rem;color:var(--muted)}

@media(max-width:768px){
  .sidebar{display:none}
  .two-col{grid-template-columns:1fr}
  .page-body,.page-header{padding-left:1rem;padding-right:1rem}
}
</style>
