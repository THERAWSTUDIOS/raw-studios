<!DOCTYPE html><html lang="en"><head><%- include('partials/head',{title}) %></head>
<body>
<%- include('partials/sidebar',{page:'enquiries',admin}) %>
<div class="admin-main">
  <div class="page-header">
    <h1>Enquiries</h1>
    <p><%= enquiries.length %> total submissions<% if(unread>0){ %> — <span style="color:var(--orange);font-weight:700"><%= unread %> unread</span><% } %></p>
  </div>
  <div class="page-body">
    <% if(enquiries.length === 0){ %>
    <div class="g-card" style="text-align:center;padding:3rem;color:var(--muted)">
      <div style="font-size:2.5rem;margin-bottom:1rem;opacity:.4">📭</div>
      <p>No enquiries yet. Contact form submissions will appear here.</p>
    </div>
    <% } else { %>
    <div style="display:flex;flex-direction:column;gap:.75rem">
      <% enquiries.forEach(e => { %>
      <div class="g-card" style="<%= !e.is_read ? 'border-color:rgba(255,98,0,0.35);' : 'opacity:.75;' %>">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap">
          <!-- Left: info -->
          <div style="flex:1;min-width:0">
            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.6rem;flex-wrap:wrap">
              <div style="font-weight:700;color:var(--text);font-size:1rem"><%= e.name || '—' %></div>
              <% if(!e.is_read){ %><span style="background:var(--orange);color:#000;font-size:.65rem;padding:2px 8px;border-radius:50px;font-weight:800">NEW</span><% } %>
              <% if(e.course){ %><span style="background:rgba(255,98,0,0.1);color:var(--orange);font-size:.72rem;padding:2px 10px;border-radius:50px;border:1px solid rgba(255,98,0,0.25)"><%= e.course %></span><% } %>
            </div>
            <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:.75rem">
              <% if(e.email){ %>
              <a href="mailto:<%= e.email %>" style="color:var(--muted);font-size:.83rem;text-decoration:none;display:flex;align-items:center;gap:.35rem">
                ✉ <%= e.email %>
              </a>
              <% } %>
              <% if(e.phone){ %>
              <a href="tel:<%= e.phone %>" style="color:var(--muted);font-size:.83rem;text-decoration:none;display:flex;align-items:center;gap:.35rem">
                📞 <%= e.phone %>
              </a>
              <% } %>
              <span style="color:var(--muted);font-size:.78rem">
                <%= new Date(e.created_at).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
              </span>
            </div>
            <% if(e.message){ %>
            <p style="color:#bbb;font-size:.87rem;line-height:1.6;background:rgba(255,255,255,0.02);padding:.75rem 1rem;border-radius:8px;border-left:2px solid rgba(255,98,0,0.3)"><%= e.message %></p>
            <% } %>
          </div>
          <!-- Right: actions -->
          <div style="display:flex;flex-direction:column;gap:.5rem;flex-shrink:0">
            <% if(!e.is_read){ %>
            <form method="POST" action="/admin/enquiries/<%= e.id %>/read">
              <button class="btn btn-ghost btn-sm" style="width:100%">✓ Mark Read</button>
            </form>
            <% } %>
            <% if(e.email){ %>
            <a href="mailto:<%= e.email %>?subject=Re: Your enquiry at The Raw Studios" class="btn btn-primary btn-sm" style="text-align:center">Reply</a>
            <% } %>
            <% if(e.phone){ %>
            <a href="https://wa.me/91<%= e.phone.replace(/\D/g,'') %>" target="_blank" class="btn btn-sm" style="background:rgba(37,211,102,0.12);color:#25d366;border:1px solid rgba(37,211,102,0.25);text-align:center">WhatsApp</a>
            <% } %>
            <form method="POST" action="/admin/enquiries/<%= e.id %>/delete" onsubmit="return confirm('Delete this enquiry?')">
              <button class="btn btn-danger btn-sm" style="width:100%">Delete</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
</body></html>
