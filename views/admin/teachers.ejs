<!DOCTYPE html><html lang="en"><head><%- include('partials/head',{title}) %></head>
<body>
<%- include('partials/sidebar',{page:'teachers',admin}) %>
<div class="admin-main">
  <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div><h1>Teachers</h1><p><%= teachers.length %> instructors on the website</p></div>
    <button class="btn btn-primary" onclick="openModal()">+ Add Teacher</button>
  </div>
  <div class="page-body">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem">
      <% teachers.forEach(t => { %>
      <div class="g-card" style="display:flex;flex-direction:column;gap:.75rem">
        <div style="display:flex;gap:.85rem;align-items:center">
          <% if(t.image){ %>
            <img src="<%= t.image %>" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,98,0,0.4);flex-shrink:0" onerror="this.style.display='none'">
          <% } else { %>
            <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--red),var(--orange));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.2rem;flex-shrink:0"><%= t.name.charAt(0) %></div>
          <% } %>
          <div>
            <div style="font-weight:700;color:var(--text)"><%= t.name %></div>
            <div style="font-size:.78rem;color:var(--muted)"><%= t.role %></div>
          </div>
        </div>
        <% if(t.tags){ %>
        <div style="display:flex;flex-wrap:wrap;gap:.35rem">
          <% t.tags.split(',').map(s=>s.trim()).filter(Boolean).forEach(tag=>{ %>
          <span class="tag-chip" style="cursor:default"><%= tag %></span>
          <% }) %>
        </div>
        <% } %>
        <div style="font-size:.8rem;color:var(--orange);font-weight:600">🏆 <%= t.experience %></div>
        <p style="font-size:.82rem;color:var(--muted);line-height:1.5;flex:1"><%= t.bio %></p>
        <div style="display:flex;gap:.5rem;margin-top:.25rem">
          <button class="btn btn-ghost btn-sm" onclick='openModal(<%= JSON.stringify(t) %>)'>Edit</button>
          <form method="POST" action="/admin/teachers/<%= t.id %>/delete" style="display:inline" onsubmit="return confirm('Delete <%= t.name %>?')">
            <button class="btn btn-danger btn-sm">Delete</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal-bg" id="modal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="modal-title">Add Teacher</h3>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <form id="teacherForm" method="POST" action="/admin/teachers">
      <div class="two-col">
        <div class="field"><label>Full Name</label><input id="f_name" name="name" required placeholder="e.g. Rounak Singh"></div>
        <div class="field"><label>Role / Title</label><input id="f_role" name="role" placeholder="e.g. Founder & Lead Instructor"></div>
      </div>
      <div class="field">
        <label>Specialisations (Enter or comma to add)</label>
        <div class="tags-editor" id="tagsEditor" onclick="document.getElementById('tagInput').focus()">
          <input id="tagInput" class="tag-input" placeholder="e.g. Guitar, Singing...">
        </div>
        <input type="hidden" id="f_tags" name="tags">
      </div>
      <div class="field"><label>Experience</label><input id="f_experience" name="experience" placeholder="e.g. 12+ Years Experience"></div>
      <div class="field"><label>Bio</label><textarea id="f_bio" name="bio" rows="3" placeholder="Short bio..."></textarea></div>
      <div class="field">
        <label>Photo</label>
        <div class="drop-zone" id="dropZone">
          <input type="file" id="fileInput" accept="image/*" onchange="handleFile(this.files[0])">
          <div class="dz-icon">📷</div>
          <div class="dz-text">Drag & drop or <span>browse</span> — JPG, PNG, WEBP (max 5MB)</div>
        </div>
        <div class="progress-bar" id="uploadProgress"></div>
        <div class="preview-wrap" id="previewWrap">
          <img class="preview-img" id="previewImg" src="" alt="">
          <span class="preview-name" id="previewName"></span>
          <button type="button" class="preview-remove" onclick="clearImage()">✕</button>
        </div>
        <input type="hidden" id="f_image" name="image">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Teacher</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let tags=[];
function renderTags(){
  const editor=document.getElementById('tagsEditor'),input=document.getElementById('tagInput');
  editor.querySelectorAll('.tag-chip').forEach(e=>e.remove());
  tags.forEach((tag,i)=>{
    const c=document.createElement('div');c.className='tag-chip';
    c.innerHTML=tag+' <button type="button" onclick="removeTag('+i+')">×</button>';
    editor.insertBefore(c,input);
  });
  document.getElementById('f_tags').value=tags.join(',');
}
function addTag(v){v=v.trim().replace(/,$/,'');if(v&&!tags.includes(v)){tags.push(v);renderTags();}}
function removeTag(i){tags.splice(i,1);renderTags();}
document.getElementById('tagInput').addEventListener('keydown',e=>{
  if(e.key==='Enter'||e.key===','){e.preventDefault();addTag(e.target.value);e.target.value='';}
  else if(e.key==='Backspace'&&!e.target.value&&tags.length){tags.pop();renderTags();}
});
document.getElementById('tagInput').addEventListener('blur',e=>{if(e.target.value.trim()){addTag(e.target.value);e.target.value='';}});

const dz=document.getElementById('dropZone');
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag-over');});
dz.addEventListener('dragleave',()=>dz.classList.remove('drag-over'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/'))handleFile(f);});

async function handleFile(file){
  if(!file)return;
  document.getElementById('previewImg').src=URL.createObjectURL(file);
  document.getElementById('previewName').textContent=file.name;
  document.getElementById('previewWrap').classList.add('show');
  const bar=document.getElementById('uploadProgress');bar.style.width='30%';
  const fd=new FormData();fd.append('image',file);
  try{
    const res=await fetch('/admin/upload/teacher-image',{method:'POST',body:fd});
    const data=await res.json();bar.style.width='100%';setTimeout(()=>bar.style.width='0',600);
    if(data.url){document.getElementById('f_image').value=data.url;document.getElementById('previewImg').src=data.url;showToast('Photo uploaded ✓');}
    else{showToast('Upload failed: '+(data.error||'error'));clearImage();}
  }catch(e){bar.style.width='0';showToast('Error: '+e.message);}
}
function clearImage(){document.getElementById('f_image').value='';document.getElementById('previewWrap').classList.remove('show');document.getElementById('previewImg').src='';document.getElementById('fileInput').value='';}

function openModal(t){
  tags=[];
  document.getElementById('modal-title').textContent=t?'Edit Teacher':'Add Teacher';
  document.getElementById('f_name').value=t?.name||'';
  document.getElementById('f_role').value=t?.role||'';
  document.getElementById('f_experience').value=t?.experience||'';
  document.getElementById('f_bio').value=t?.bio||'';
  document.getElementById('f_image').value=t?.image||'';
  if(t?.tags)t.tags.split(',').map(s=>s.trim()).filter(Boolean).forEach(addTag);else renderTags();
  if(t?.image){document.getElementById('previewImg').src=t.image;document.getElementById('previewName').textContent='Current photo';document.getElementById('previewWrap').classList.add('show');}
  else clearImage();
  document.getElementById('teacherForm').action=t?'/admin/teachers/'+t.id+'/update':'/admin/teachers';
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}
document.getElementById('modal').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});
document.getElementById('teacherForm').addEventListener('submit',()=>{
  if(document.getElementById('tagInput').value.trim()){addTag(document.getElementById('tagInput').value);}
  document.getElementById('f_tags').value=tags.join(',');
});
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}
</script>
</body></html>
