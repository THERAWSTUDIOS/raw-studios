<!DOCTYPE html><html lang="en"><head><%- include('partials/head',{title}) %></head>
<body>
<%- include('partials/sidebar',{page:'courses',admin}) %>
<div class="admin-main">
  <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1>Courses</h1>
      <p><%= courses.length %> courses on the website</p>
    </div>
    <button class="btn btn-primary" onclick="openAdd()">+ Add Course</button>
  </div>
  <div class="page-body">
    <div class="g-card" style="padding:0;overflow:hidden">
      <table class="g-table">
        <thead><tr>
          <th>Course</th><th>Instructor</th><th>Category</th><th>Price</th><th>Actions</th>
        </tr></thead>
        <tbody>
          <% courses.forEach(c => { %>
          <tr>
            <td>
              <% if(c.image){ %><img src="<%= c.image %>" style="width:36px;height:36px;object-fit:cover;border-radius:6px;margin-right:.6rem;vertical-align:middle" onerror="this.style.display='none'"><% } %>
              <strong style="color:var(--text)"><%= c.title %></strong>
            </td>
            <td style="color:var(--muted)"><%= c.instructor %></td>
            <td><span style="background:rgba(255,98,0,0.1);color:var(--orange);border-radius:50px;padding:2px 10px;font-size:.75rem;font-weight:600;text-transform:uppercase"><%= c.category %></span></td>
            <td style="color:var(--muted)"><%= c.price %></td>
            <td><div class="td-actions">
              <button class="btn btn-ghost btn-sm" onclick='openEdit(<%= JSON.stringify(c) %>)'>Edit</button>
              <form method="POST" action="/admin/courses/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('Delete «<%= c.title %>»?')">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal-bg" id="addModal">
  <div class="modal">
    <div class="modal-header">
      <h3>Add Course</h3>
      <button class="modal-close" onclick="document.getElementById('addModal').classList.remove('open')">×</button>
    </div>
    <form method="POST" action="/admin/courses">
      <div class="two-col">
        <div class="field"><label>Title</label><input name="title" required placeholder="e.g. Guitar Classes"></div>
        <div class="field"><label>Instructor</label><input name="instructor" required placeholder="e.g. Rounak Singh"></div>
      </div>
      <div class="two-col">
        <div class="field"><label>Category</label>
          <select name="category"><option value="music">Music</option><option value="dance">Dance</option></select>
        </div>
        <div class="field"><label>Price</label><input name="price" value="₹2,499"></div>
      </div>
      <div class="field"><label>Icon (FontAwesome, e.g. fa-guitar)</label><input name="icon" placeholder="fa-guitar"></div>
      <div class="field"><label>Description</label><textarea name="description" rows="3" placeholder="Short course description..."></textarea></div>
      <div class="field"><label>Image Path (e.g. /images/courses/guitar.jpg)</label><input name="image" placeholder="/images/courses/guitar.jpg"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('addModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary">Add Course</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-bg" id="editModal">
  <div class="modal">
    <div class="modal-header">
      <h3>Edit Course</h3>
      <button class="modal-close" onclick="document.getElementById('editModal').classList.remove('open')">×</button>
    </div>
    <form id="editForm" method="POST">
      <div class="two-col">
        <div class="field"><label>Title</label><input id="e_title" name="title" required></div>
        <div class="field"><label>Instructor</label><input id="e_instructor" name="instructor" required></div>
      </div>
      <div class="two-col">
        <div class="field"><label>Category</label>
          <select id="e_category" name="category"><option value="music">Music</option><option value="dance">Dance</option></select>
        </div>
        <div class="field"><label>Price</label><input id="e_price" name="price"></div>
      </div>
      <div class="field"><label>Icon</label><input id="e_icon" name="icon"></div>
      <div class="field"><label>Description</label><textarea id="e_desc" name="description" rows="3"></textarea></div>
      <div class="field"><label>Image Path</label><input id="e_image" name="image"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('editModal').classList.remove('open')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function openAdd(){ document.getElementById('addModal').classList.add('open'); }
function openEdit(c){
  document.getElementById('editForm').action='/admin/courses/'+c.id+'/update';
  document.getElementById('e_title').value=c.title||'';
  document.getElementById('e_instructor').value=c.instructor||'';
  document.getElementById('e_category').value=c.category||'music';
  document.getElementById('e_price').value=c.price||'';
  document.getElementById('e_icon').value=c.icon||'';
  document.getElementById('e_desc').value=c.description||'';
  document.getElementById('e_image').value=c.image||'';
  document.getElementById('editModal').classList.add('open');
}
document.querySelectorAll('.modal-bg').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open')}));
</script>
</body></html>
