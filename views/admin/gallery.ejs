<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#0a0a0a; color:#fff; font-family:'Segoe UI',sans-serif; }
    header { background:#111; border-bottom:1px solid #FA8112; padding:1rem 2rem;
             display:flex; justify-content:space-between; align-items:center; }
    header h1 { color:#FA8112; font-size:1.2rem; letter-spacing:2px; }
    nav a { color:#aaa; text-decoration:none; margin-left:1rem; font-size:.85rem; }
    nav a:hover { color:#FA8112; }
    .main { padding:2rem; max-width:1200px; margin:0 auto; }
    h2 { color:#FA8112; margin-bottom:1.5rem; }
    .btn { padding:.5rem 1rem; border:none; border-radius:6px; cursor:pointer; font-size:.85rem; }
    .btn-primary { background:#FA8112; color:#000; font-weight:700; }
    .btn-danger { background:#c0392b; color:#fff; }
    .btn-sm { padding:.35rem .7rem; font-size:.8rem; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:1rem; margin-top:1rem; }
    .img-card { background:#111; border:1px solid #222; border-radius:8px; overflow:hidden; }
    .img-card img { width:100%; height:160px; object-fit:cover; }
    .img-card .info { padding:.75rem; }
    .img-card .info p { color:#888; font-size:.8rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .modal-bg { display:none; position:fixed; inset:0; background:rgba(0,0,0,.85); z-index:100;
                align-items:center; justify-content:center; }
    .modal-bg.open { display:flex; }
    .modal { background:#111; border:1px solid #FA8112; border-radius:12px; padding:2rem;
             width:100%; max-width:460px; }
    .modal h3 { color:#FA8112; margin-bottom:1.2rem; }
    label { display:block; color:#aaa; font-size:.8rem; margin-bottom:.3rem; margin-top:.8rem; }
    input { width:100%; padding:.65rem .9rem; background:#1a1a1a; border:1px solid #333;
            border-radius:6px; color:#fff; font-size:.9rem; }
    input:focus { outline:none; border-color:#FA8112; }
    .modal-footer { margin-top:1.5rem; display:flex; gap:.75rem; justify-content:flex-end; }
    .cancel-btn { background:#333; color:#fff; padding:.6rem 1.2rem; border:none; border-radius:6px; cursor:pointer; }
  </style>
</head>
<body>
  <header>
    <h1>TRS ADMIN — Gallery</h1>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/courses">Courses</a>
      <a href="/admin/teachers">Teachers</a>
      <a href="/admin/logout">Logout</a>
    </nav>
  </header>
  <div class="main">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
      <h2>Student Gallery (<%= gallery.length %> photos)</h2>
      <button class="btn btn-primary" onclick="document.getElementById('addModal').classList.add('open')">+ Add Photo</button>
    </div>
    <div class="grid">
      <% gallery.forEach(g => { %>
      <div class="img-card">
        <img src="<%= g.image_url %>" alt="<%= g.caption || 'Gallery' %>" onerror="this.src='/images/col.jpeg'">
        <div class="info">
          <p title="<%= g.caption %>"><%= g.caption || '—' %></p>
          <form method="POST" action="/admin/gallery/<%= g.id %>/delete" style="margin-top:.5rem;"
                onsubmit="return confirm('Remove this photo?')">
            <button class="btn btn-sm btn-danger" style="width:100%">Remove</button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <div class="modal-bg" id="addModal">
    <div class="modal">
      <h3>Add Gallery Photo</h3>
      <form method="POST" action="/admin/gallery">
        <label>Image URL (paste Supabase storage URL or /images/... path)</label>
        <input name="image_url" required placeholder="https://... or /images/col.jpeg">
        <label>Caption (optional)</label>
        <input name="caption" placeholder="Performance at Annual Fest 2024">
        <div class="modal-footer">
          <button type="button" class="cancel-btn"
                  onclick="document.getElementById('addModal').classList.remove('open')">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Photo</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('addModal').addEventListener('click', e => {
      if(e.target===e.currentTarget) e.currentTarget.classList.remove('open');
    });
  </script>
</body>
</html>
