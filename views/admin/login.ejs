<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= title %></title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#080808;font-family:'Segoe UI',system-ui,sans-serif;position:relative;overflow:hidden}
body::before{content:'';position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(217,56,0,0.12),transparent 70%);top:-100px;right:-100px;pointer-events:none}
body::after{content:'';position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(255,179,0,0.07),transparent 70%);bottom:-100px;left:-100px;pointer-events:none}
.card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,98,0,0.2);border-radius:20px;padding:2.5rem 2rem;width:100%;max-width:380px;position:relative;z-index:1;backdrop-filter:blur(10px)}
.card::before{content:'';position:absolute;top:0;left:10%;right:10%;height:2px;background:linear-gradient(90deg,#D93800,#FF6200,#FFB300,#FF6200,#D93800);border-radius:2px}
.logo{text-align:center;margin-bottom:2rem}
.logo .brand{font-size:.7rem;letter-spacing:4px;color:#555;text-transform:uppercase}
.logo h1{font-size:1.5rem;font-weight:800;background:linear-gradient(135deg,#D93800,#FF6200,#FFB300);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:1px;margin-top:.3rem}
.logo p{color:#555;font-size:.8rem;margin-top:.3rem}
label{display:block;color:#666;font-size:.75rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:.4rem}
input{width:100%;padding:.8rem 1rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;color:#f0f0f0;font-size:.95rem;margin-bottom:1.1rem;transition:.2s}
input:focus{outline:none;border-color:#FF6200;background:rgba(255,98,0,0.04)}
button{width:100%;padding:.9rem;background:linear-gradient(135deg,#D93800,#FF6200);color:#fff;font-weight:700;border:none;border-radius:10px;font-size:1rem;cursor:pointer;transition:.2s;letter-spacing:.5px}
button:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 8px 24px rgba(255,98,0,0.3)}
.error{background:rgba(192,57,43,0.12);border:1px solid rgba(192,57,43,0.3);color:#e74c3c;padding:.75rem 1rem;border-radius:8px;margin-bottom:1.1rem;font-size:.83rem}
</style>
</head>
<body>
<div class="card">
  <div class="logo">
    <div class="brand">The Raw Studios</div>
    <h1>Admin Panel</h1>
    <p>Sign in to manage your studio</p>
  </div>
  <% if(error){ %><div class="error">⚠ <%= error %></div><% } %>
  <form method="POST" action="/trstestrounak">
    <label>Username</label>
    <input type="text" name="username" required autocomplete="username" placeholder="Enter username">
    <label>Password</label>
    <input type="password" name="password" required autocomplete="current-password" placeholder="Enter password">
    <button type="submit">Sign In →</button>
  </form>
</div>
</body></html>
