<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { min-height:100vh; display:flex; align-items:center; justify-content:center;
           background:#0a0a0a; font-family:'Segoe UI',sans-serif; }
    .card { background:#111; border:1px solid #FA8112; border-radius:12px;
            padding:2.5rem 2rem; width:100%; max-width:380px; }
    .logo { text-align:center; margin-bottom:1.5rem; }
    .logo h1 { color:#FA8112; font-size:1.4rem; letter-spacing:2px; }
    .logo p { color:#666; font-size:.8rem; margin-top:.3rem; }
    label { display:block; color:#aaa; font-size:.85rem; margin-bottom:.4rem; }
    input { width:100%; padding:.75rem 1rem; background:#1a1a1a; border:1px solid #333;
            border-radius:8px; color:#fff; font-size:.95rem; margin-bottom:1rem; }
    input:focus { outline:none; border-color:#FA8112; }
    button { width:100%; padding:.85rem; background:#FA8112; color:#000; font-weight:700;
             border:none; border-radius:8px; font-size:1rem; cursor:pointer; transition:.2s; }
    button:hover { background:#e07000; }
    .error { background:#3a1a1a; border:1px solid #c0392b; color:#e74c3c;
             padding:.75rem 1rem; border-radius:8px; margin-bottom:1rem; font-size:.85rem; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <h1>THE RAW STUDIOS</h1>
      <p>Admin Access</p>
    </div>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/trstestrounak">
      <label>Username</label>
      <input type="text" name="username" required autocomplete="username">
      <label>Password</label>
      <input type="password" name="password" required autocomplete="current-password">
      <button type="submit">Login</button>
    </form>
  </div>
</body>
</html>
