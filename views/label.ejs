<%- include('partials/head', {title}) %>
<%- include('partials/navbar') %>

<!-- Page Hero -->
<section class="page-hero" id="label-page">
  <div class="page-hero-bg"></div>
  <div class="container text-center">
    <span class="section-tag gsap-fade-up" data-delay="0.1">Record Label</span>
    <h1 class="page-hero-title gsap-fade-up" data-delay="0.2">TRS <span class="text-gradient">Label</span></h1>
    <p class="page-hero-subtitle gsap-fade-up" data-delay="0.35">Watch our live performances, student showcases, and original recordings.</p>
  </div>
</section>

<!-- Videos Grid -->
<section class="trs-section label-section">
  <div class="container">
    <div class="section-header text-center mb-5">
      <span class="section-tag gsap-reveal">Watch & Listen</span>
      <h2 class="section-title gsap-reveal">Live Performances &amp; <span class="text-gradient">Original Music</span></h2>
      <p class="section-subtitle gsap-reveal">Hover to preview, click to watch our amazing performances on YouTube.</p>
    </div>

    <div class="row g-4 videos-grid">
      <% videos.forEach((video, i) => { %>
      <div class="col-sm-6 col-lg-4 gsap-card" data-index="<%= i %>">
        <div class="video-card" data-videoid="<%= video.id %>">
          <!-- Thumbnail (shown by default) -->
          <div class="video-thumbnail" id="thumb-<%= i %>">
            <img
              src="https://img.youtube.com/vi/<%= video.id %>/maxresdefault.jpg"
              alt="<%= video.title %>"
              onerror="this.src='https://img.youtube.com/vi/<%= video.id %>/hqdefault.jpg'"
              class="thumb-img"
              loading="lazy"
            />
            <div class="video-overlay">
              <div class="play-btn-wrap">
                <div class="play-btn"><i class="fa-solid fa-play"></i></div>
                <div class="play-ripple"></div>
                <div class="play-ripple delay1"></div>
              </div>
            </div>
          </div>

          <!-- Iframe (loaded on click) -->
          <div class="video-iframe-wrap" id="iframe-<%= i %>" style="display:none;">
            <!-- iframe injected by JS -->
          </div>

          <div class="video-info">
            <h4 class="video-title"><%= video.title %></h4>
            <p class="video-artist"><i class="fa-solid fa-user-music me-1"></i><%= video.artist %></p>
            <a href="https://www.youtube.com/watch?v=<%= video.id %>" target="_blank" rel="noopener" class="youtube-link">
              <i class="fa-brands fa-youtube me-1"></i> Watch on YouTube
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="text-center mt-5 gsap-reveal">
      <p class="label-cta-text">Are you an independent artist? Partner with us!</p>
      <a href="/contact" class="btn btn-primary-trs btn-magnetic">
        <i class="fa-solid fa-record-vinyl me-2"></i>Collaborate With TRS Label
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script>
  // Video card click-to-play
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.video-card').forEach((card, i) => {
      const videoId = card.dataset.videoid;
      const thumb = document.getElementById('thumb-' + i);
      const iframeWrap = document.getElementById('iframe-' + i);

      // Hover: scale effect via CSS, GSAP pulse
      card.addEventListener('mouseenter', () => {
        gsap.to(card.querySelector('.play-btn'), { scale: 1.15, duration: 0.3, ease: 'back.out(2)' });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card.querySelector('.play-btn'), { scale: 1, duration: 0.3 });
      });

      // Click: load iframe with autoplay
      thumb.addEventListener('click', () => {
        gsap.to(thumb, {
          opacity: 0, scale: 1.05, duration: 0.3, ease: 'power2.in',
          onComplete: () => {
            thumb.style.display = 'none';
            iframeWrap.style.display = 'block';
            iframeWrap.innerHTML = `<iframe
              src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="video-iframe"
            ></iframe>`;
            gsap.from(iframeWrap, { opacity: 0, scale: 0.95, duration: 0.4, ease: 'power2.out' });
          }
        });
      });
    });
  });
</script>
