<%- include('partials/head', {title}) %>
<%- include('partials/navbar') %>

<!-- Page Hero -->
<section class="page-hero" id="courses-page">
  <div class="page-hero-bg"></div>
  <div class="container text-center">
    <span class="section-tag gsap-fade-up" data-delay="0.1">What We Offer</span>
    <h1 class="page-hero-title gsap-fade-up" data-delay="0.2">Our <span class="text-gradient">Courses</span></h1>
    <p class="page-hero-subtitle gsap-fade-up" data-delay="0.35">Explore our comprehensive range of music and dance programs designed to nurture your artistic growth.</p>
  </div>
</section>

<!-- Filter Tabs -->
<section class="trs-section courses-full-section">
  <div class="container">
    <!-- Filter Buttons -->
    <div class="filter-tabs gsap-reveal text-center mb-5">
      <button class="filter-btn active btn-magnetic" data-filter="all">
        <i class="fa-solid fa-grip me-2"></i>All Courses
      </button>
      <button class="filter-btn btn-magnetic" data-filter="music">
        <i class="fa-solid fa-music me-2"></i>Music
      </button>
      <button class="filter-btn btn-magnetic" data-filter="dance">
        <i class="fa-solid fa-person-walking me-2"></i>Dance &amp; Wellness
      </button>
    </div>

    <!-- Courses Grid -->
    <div class="row g-4 courses-full-grid" id="coursesGrid">
      <% courses.forEach((course, i) => { %>
      <div class="col-sm-6 col-lg-4 course-item gsap-card" data-category="<%= course.category %>" data-index="<%= i %>">
        <div class="course-card course-card-full" style="--card-color: <%= course.color %>">
          <div class="course-card-glow"></div>
          <% if (course.image) { %>
          <div class="course-card-img-wrap">
            <img src="<%= course.image %>" alt="<%= course.title %>" class="course-card-img" loading="lazy" onerror="this.parentElement.style.display='none'"/>
          </div>
          <% } %>
          <div class="course-card-header">
            <div class="course-icon-wrap large">
              <i class="fa-solid <%= course.icon %>"></i>
            </div>
            <span class="course-category-tag"><%= course.category === 'music' ? 'Music' : 'Dance & Wellness' %></span>
          </div>
          <div class="course-card-body">
            <h3 class="course-title"><%= course.title %></h3>
            <p class="course-by">By <strong><%= course.instructor %></strong></p>
            <p class="course-desc"><%= course.desc %></p>
          </div>
          <div class="course-card-footer">
            <span class="course-price-big">From <strong><%= course.price %></strong>/–</span>
            <a href="/contact" class="btn btn-enroll btn-magnetic">
              Enroll Now <i class="fa-solid fa-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner gsap-reveal">
  <div class="cta-banner-glow"></div>
  <div class="container text-center">
    <h2 class="cta-title">Not Sure Which Course to <span class="text-gradient">Pick?</span></h2>
    <p class="cta-subtitle">Book a free trial lesson and let our instructors guide you to the right choice.</p>
    <a href="/contact" class="btn btn-primary-trs btn-magnetic">
      <i class="fa-solid fa-calendar-check me-2"></i>Book Free Trial
    </a>
  </div>
</section>

<%- include('partials/footer') %>
