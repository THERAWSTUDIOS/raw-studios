<footer class="trs-footer">
  <!-- Wave divider: transitions from last section cream (#FAF3E1) to footer dark (#222222) -->
  <div class="footer-wave" style="background: #FAF3E1">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#222222"/>
    </svg>
  </div>

  <div class="container">
    <!-- Top footer: Get In Touch + Map + Form -->
    <div class="footer-top">
      <div class="row g-5 align-items-start">
        <!-- Left: Contact info -->
        <div class="col-lg-4">
          <h2 class="footer-heading gsap-footer">Get In Touch</h2>
          <p class="footer-subtext gsap-footer">Ready to start your musical or dance journey? Contact us today to schedule a trial lesson.</p>

          <div class="contact-info-list">
            <div class="contact-info-item gsap-footer">
              <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
              <div>
                <strong>Visit Our Academy</strong>
                <p>The Raw Studios, First Floor, Sodhi Complex, SCO 1, VIP Rd, near SGR Clinic, Rail Vihar, Zirakpur, Punjab</p>
              </div>
            </div>
            <div class="contact-info-item gsap-footer">
              <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
              <div>
                <strong>Email Us</strong>
                <p><a href="mailto:therawstudioofficial@gmail.com">therawstudioofficial@gmail.com</a></p>
              </div>
            </div>
            <div class="contact-info-item gsap-footer">
              <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
              <div>
                <strong>Call Us</strong>
                <p>Mon–Sun, 8am – 8pm</p>
                <p><a href="tel:+919754444450">+91 9754444450</a></p>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div class="social-links gsap-footer">
            <a href="#" class="social-link" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
            <a href="https://www.instagram.com/therawstudiosofficial" target="_blank" class="social-link" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
            <a href="#" class="social-link" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
          </div>
        </div>

        <!-- Middle: Quick links + brand -->
        <div class="col-lg-4">
          <div class="footer-brand-block gsap-footer">
            <div class="footer-logo">
              <i class="fa-solid fa-music"></i>
              <span>The Raw Studios</span>
            </div>
            <p class="footer-about">The Raw Studios Music Academy was formed in 2018 with a vision to spread quality music education across India.</p>
            <p class="footer-call">
              <i class="fa-solid fa-phone-volume"></i>
              Got Questions? Call us<br/>
              <a href="tel:+919754444450">+91 9754444450</a><br/>
              <a href="mailto:therawstudioofficial@gmail.com">therawstudioofficial@gmail.com</a>
            </p>
          </div>

          <div class="quick-links gsap-footer">
            <h4>Quick Links</h4>
            <ul>
              <li><a href="/about"><i class="fa-solid fa-chevron-right"></i> About Us</a></li>
              <li><a href="/courses"><i class="fa-solid fa-chevron-right"></i> Courses</a></li>
              <li><a href="#faq"><i class="fa-solid fa-chevron-right"></i> FAQ's</a></li>
              <li><a href="/label"><i class="fa-solid fa-chevron-right"></i> Label</a></li>
              <li><a href="/contact"><i class="fa-solid fa-chevron-right"></i> Contact Us</a></li>
            </ul>
          </div>
        </div>

        <!-- Right: Message form -->
        <div class="col-lg-4">
          <div class="footer-form-card gsap-footer">
            <h3>Send Us a Message</h3>
            <form action="/contact" method="POST" class="footer-form">
              <div class="mb-3">
                <input type="text" name="firstName" class="form-control trs-input" placeholder="First Name *" required/>
              </div>
              <div class="mb-3">
                <input type="tel" name="phone" class="form-control trs-input" placeholder="Phone Number *" required/>
              </div>
              <div class="mb-3">
                <input type="email" name="email" class="form-control trs-input" placeholder="Email Address *" required/>
              </div>
              <div class="mb-3">
                <textarea name="message" rows="3" class="form-control trs-input" placeholder="Your message..."></textarea>
              </div>
              <button type="submit" class="btn btn-footer-submit w-100 btn-magnetic">
                <i class="fa-solid fa-paper-plane me-2"></i> Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>© <%= new Date().getFullYear() %> The Raw Studios. All rights reserved. Made with <span class="heart">♥</span> in Zirakpur, Punjab.</p>
      <div class="footer-bottom-social">
        <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
        <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
      </div>
    </div>
  </div>
