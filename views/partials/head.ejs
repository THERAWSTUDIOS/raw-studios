<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5"/>
  <meta name="description" content="The Raw Studios — Professional music and dance academy in Zirakpur, Punjab. Singing, Guitar, Piano, Kathak, Bhangra and more."/>
  <title><%= title %></title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <!-- Google Fonts: Bebas Neue (funky display) + Great Vibes + Playfair + Poppins + Space Grotesk -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Bebas+Neue&family=Great+Vibes&family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Poppins:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet"/>
  <!-- Swiper -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css"/>
  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎵</text></svg>"/>
</head>
<body>

<!-- ══════════════════════════════════════════════
     FULL-SCREEN PAGE LOADER (dismissed by JS on load)
═══════════════════════════════════════════════ -->
<div id="trs-loader" aria-hidden="true">
  <div class="loader-orb lo-1"></div>
  <div class="loader-orb lo-2"></div>
  <div class="loader-orb lo-3"></div>
  <div class="loader-staff-lines" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span>
  </div>
  <div class="loader-content">
    <i class="fa-solid fa-music loader-music-icon"></i>
    <div class="loader-brand-text">The Raw Studios</div>
    <p class="loader-tagline">Music &nbsp;&middot;&nbsp; Dance &nbsp;&middot;&nbsp; Art</p>
    <div class="loader-progress-wrap">
      <div class="loader-progress-track">
        <div class="loader-progress-fill"></div>
      </div>
    </div>
    <div class="loader-notes-row" aria-hidden="true">
      <span>&#9834;</span><span>&#9835;</span><span>&#9833;</span><span>&#9836;</span><span>&#9837;</span>
    </div>
  </div>
</div>
