<%- include('partials/head', {title}) %>
<%- include('partials/navbar') %>

<!-- Page Hero -->
<section class="page-hero contact-hero" id="contact-page">
  <div class="page-hero-bg"></div>
  <div class="container text-center">
    <span class="section-tag gsap-fade-up" data-delay="0.1">Let's Talk</span>
    <h1 class="page-hero-title gsap-fade-up" data-delay="0.2">Get in <span class="text-gradient">Touch</span></h1>
    <p class="page-hero-subtitle gsap-fade-up" data-delay="0.35">We are here to answer any question you may have.</p>
  </div>
</section>

<!-- Contact Section -->
<section class="trs-section contact-section">
  <div class="container">
    <div class="row g-5 align-items-start">
      <!-- Contact Info -->
      <div class="col-lg-5 gsap-reveal" data-dir="left">
        <div class="contact-info-card">
          <h2 class="contact-info-title">Contact <span class="text-gradient">Details</span></h2>
          <p class="contact-info-subtitle">Speak to our friendly team — we'd love to hear from you!</p>

          <div class="contact-detail-item">
            <div class="cd-icon" style="--ci: #4ea8f3"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <h5>Email Us</h5>
              <a href="mailto:therawstudioofficial@gmail.com">therawstudioofficial@gmail.com</a>
            </div>
          </div>
          <div class="contact-detail-item">
            <div class="cd-icon" style="--ci: #b06cf4"><i class="fa-solid fa-phone"></i></div>
            <div>
              <h5>Call Us</h5>
              <p>Mon–Sun, 8am – 8pm</p>
              <a href="tel:+919754444450">+91 9754444450</a>
            </div>
          </div>
          <div class="contact-detail-item">
            <div class="cd-icon" style="--ci: #4fe8c8"><i class="fa-solid fa-location-dot"></i></div>
            <div>
              <h5>Visit Us</h5>
              <p>The Raw Studios, First Floor, Sodhi Complex, SCO 1, VIP Rd, near SGR Clinic, Rail Vihar, Zirakpur, Punjab</p>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="map-embed">
            <iframe
              src="https://maps.google.com/maps?q=Rail+Vihar+Zirakpur+Punjab&output=embed"
              width="100%"
              height="220"
              style="border:0;border-radius:12px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="The Raw Studios Location"
            ></iframe>
          </div>

          <div class="contact-social mt-4">
            <a href="#" class="social-link" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
            <a href="https://www.instagram.com/therawstudiosofficial" target="_blank" class="social-link" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
            <a href="#" class="social-link" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="col-lg-7 gsap-reveal" data-dir="right">
        <div class="contact-form-card">
          <h2 class="contact-form-title">Send a Message <span style="font-style:normal;">👍🏻</span></h2>
          <p class="contact-form-subtitle">Fill out the form below and we'll get back to you within 24 hours.</p>

          <div id="successMsg" style="display:none" class="alert trs-alert-success" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>We received your enquiry! Our team will reach out to you on WhatsApp shortly.
          </div>

          <form class="contact-form" id="contactForm" novalidate>
            <div class="row g-4">
              <div class="col-12">
                <div class="trs-form-group">
                  <label class="trs-label">Full Name <span class="required">*</span></label>
                  <div class="trs-input-wrap">
                    <i class="fa-solid fa-user input-icon"></i>
                    <input type="text" name="name" class="form-control trs-input-field" placeholder="Your full name" required/>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="trs-form-group">
                  <label class="trs-label">Phone Number <span class="required">*</span></label>
                  <div class="trs-input-wrap">
                    <i class="fa-solid fa-phone input-icon"></i>
                    <input type="tel" name="phone" class="form-control trs-input-field" placeholder="+91 XXXXX XXXXX" required/>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="trs-form-group">
                  <label class="trs-label">Email Address <span class="required">*</span></label>
                  <div class="trs-input-wrap">
                    <i class="fa-solid fa-envelope input-icon"></i>
                    <input type="email" name="email" class="form-control trs-input-field" placeholder="you@example.com" required/>
                  </div>
                </div>
              </div>
              <div class="col-12">
                <div class="trs-form-group">
                  <label class="trs-label">Course Interested In</label>
                  <div class="trs-input-wrap">
                    <i class="fa-solid fa-music input-icon"></i>
                    <select name="course" class="form-control trs-input-field trs-select">
                      <option value="">Select a course (optional)</option>
                      <option>Singing Classes</option>
                      <option>Guitar Classes</option>
                      <option>Piano Classes</option>
                      <option>Flute Classes</option>
                      <option>Drums</option>
                      <option>Cajon / Clapbox</option>
                      <option>Violin</option>
                      <option>Sitar</option>
                      <option>Western Dance</option>
                      <option>Classical Dance (Kathak)</option>
                      <option>Bhangra</option>
                      <option>Yoga</option>
                      <option>Other / General Enquiry</option>
                    </select>
                  </div>
                </div>
              </div>
              <div class="col-12">
                <div class="trs-form-group">
                  <label class="trs-label">Your Message / Concern</label>
                  <div class="trs-input-wrap">
                    <i class="fa-solid fa-comment-dots input-icon" style="top:1rem;transform:none"></i>
                    <textarea name="concern" class="form-control trs-input-field" placeholder="Tell us about your goals, questions, or any specific requirements…" rows="3" style="padding-top:.75rem;resize:vertical"></textarea>
                  </div>
                </div>
              </div>
              <div class="col-12">
                <label class="trs-lead-checkbox" id="leadLabel">
                  <input type="checkbox" id="confirmLead" name="is_lead"/>
                  <span class="lead-checkbox-box"><i class="fa-solid fa-check"></i></span>
                  <span class="lead-checkbox-text">I confirm the provided information is correct — connect me on <strong>WhatsApp</strong> instantly</span>
                  <span class="lead-wa-badge"><i class="fa-brands fa-whatsapp"></i></span>
                </label>
              </div>
            </div>

            <button type="submit" class="btn btn-submit-big btn-magnetic mt-4 w-100" id="submitBtn">
              <span class="btn-text"><i class="fa-solid fa-paper-plane me-2"></i>Send Message</span>
              <span class="btn-loading" style="display:none"><i class="fa-solid fa-spinner fa-spin me-2"></i>Sending…</span>
            </button>
          </form>

          <style>
            .trs-lead-checkbox{display:flex;align-items:center;gap:.75rem;cursor:pointer;padding:.85rem 1.1rem;border-radius:12px;border:1.5px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);transition:.3s}
            .trs-lead-checkbox:hover{border-color:rgba(37,211,102,0.3);background:rgba(37,211,102,0.04)}
            .trs-lead-checkbox input{display:none}
            .lead-checkbox-box{width:20px;height:20px;border-radius:5px;border:2px solid rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.25s;color:#fff;font-size:.65rem}
            .trs-lead-checkbox input:checked ~ .lead-checkbox-box{background:#25d366;border-color:#25d366}
            .lead-checkbox-text{flex:1;font-size:.84rem;color:var(--muted);transition:.25s}
            .trs-lead-checkbox input:checked ~ .lead-checkbox-box ~ .lead-checkbox-text{color:var(--text)}
            .lead-wa-badge{background:rgba(37,211,102,0.12);color:#25d366;border:1px solid rgba(37,211,102,0.3);border-radius:50px;padding:3px 10px;font-size:.78rem;flex-shrink:0}
            .lead-active{border-color:rgba(37,211,102,0.45)!important;background:rgba(37,211,102,0.06)!important}
            .btn-submit-big{transition:background .3s,box-shadow .3s}
            .btn-submit-wa{background:linear-gradient(135deg,#25d366,#128c7e)!important;box-shadow:0 4px 20px rgba(37,211,102,0.35)!important}
          </style>
          <script>
          (function(){
            const form    = document.getElementById('contactForm');
            const cb      = document.getElementById('confirmLead');
            const label   = document.getElementById('leadLabel');
            const submitBtn = document.getElementById('submitBtn');
            const successDiv = document.getElementById('successMsg');

            cb.addEventListener('change', () => {
              label.classList.toggle('lead-active', cb.checked);
              submitBtn.classList.toggle('btn-submit-wa', cb.checked);
              if(cb.checked){
                submitBtn.querySelector('.btn-text').innerHTML = '<i class="fa-brands fa-whatsapp me-2"></i>Send & Open WhatsApp';
              } else {
                submitBtn.querySelector('.btn-text').innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i>Send Message';
              }
            });

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              const name    = form.querySelector('[name="name"]').value.trim();
              const phone   = form.querySelector('[name="phone"]').value.trim();
              const email   = form.querySelector('[name="email"]').value.trim();
              const course  = form.querySelector('[name="course"]').value;
              const concern = form.querySelector('[name="concern"]').value.trim();
              const isLead  = cb.checked;

              if(!name || !phone || !email){ alert('Please fill in Name, Phone and Email.'); return; }

              const btnText    = submitBtn.querySelector('.btn-text');
              const btnLoading = submitBtn.querySelector('.btn-loading');
              btnText.style.display = 'none';
              btnLoading.style.display = '';
              submitBtn.disabled = true;

              try {
                await fetch('/contact', {
                  method: 'POST',
                  headers: {'Content-Type':'application/x-www-form-urlencoded'},
                  body: new URLSearchParams({name, phone, email, course, concern, is_lead: isLead ? '1' : '0'})
                });

                form.reset();
                label.classList.remove('lead-active');
                submitBtn.classList.remove('btn-submit-wa');
                successDiv.style.display = '';
                successDiv.scrollIntoView({behavior:'smooth', block:'nearest'});

                if(isLead){
                  const txt = encodeURIComponent(
                    'Hi, I\'m ' + name + '. I\'m interested in ' + (course || 'your courses') + '.' +
                    (concern ? ' My concern: ' + concern + '.' : '') +
                    ' Contact me at: ' + phone
                  );
                  setTimeout(() => window.open('https://wa.me/919754444450?text=' + txt, '_blank'), 400);
                }
              } catch(err) {
                alert('Something went wrong. Please try again or call us directly.');
              } finally {
                btnText.style.display = '';
                btnLoading.style.display = 'none';
                btnText.innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i>Send Message';
                submitBtn.disabled = false;
              }
            });
          })();
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
