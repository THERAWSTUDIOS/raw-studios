<%- include('partials/head', {title}) %>
<%- include('partials/navbar') %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&display=swap" rel="stylesheet">
<!-- ══════════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════════ -->
<section class="hero-section" id="hero-section">
  <div class="float-orb orb-1"></div>
  <div class="float-orb orb-2"></div>
  <div class="float-orb orb-3"></div>
  <div class="hero-bg-aurora"></div>
  <div class="hero-particles" id="heroParticles"></div>
  <div class="staff-layer" id="heroStaffLayer"></div>

  <div class="hero-content container text-center">
    <div class="hero-badge gsap-fade-up" data-delay="0">
      <i class="fa-solid fa-location-dot me-2"></i>Tri-City's Premier Music Academy
    </div>
    <div class="hero-brand-wrap">
      <h1 class="hero-brand gsap-brand" style=font-family:Oswald;text-transform: capitalize; >THE RAW STUDIOS</h1>
    </div>
    <h2 class="hero-title gsap-fade-up" data-delay="0.3">
      Discover Your <span class="text-gradient">Musical &amp; Dance</span> Journey
    </h2>
    <p class="hero-subtitle gsap-fade-up" data-delay="0.5">
      Professional instruction in music and dance for all ages and skill levels.<br/>
      Join our vibrant community of artists and unlock your creative potential.
    </p>
    <div class="hero-ctas gsap-fade-up" data-delay="0.7">
      <a href="/courses" class="btn btn-primary-trs btn-magnetic me-3">
        <i class="fa-solid fa-music me-2"></i>Explore Courses
      </a>
      <a href="/contact" class="btn btn-outline-trs btn-magnetic">
        <i class="fa-solid fa-calendar-check me-2"></i>Book Trial Lesson
      </a>
    </div>
    <div class="hero-scroll-hint gsap-fade-up" data-delay="1">
      <span>Scroll to explore</span>
      <div class="scroll-dot"></div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     OUR COURSES — PREVIEW
═══════════════════════════════════════════════ -->
<section class="trs-section courses-preview-section" id="courses-preview" style="background:#FFFFFF; position:relative; overflow:hidden;">
  <div class="staff-layer" id="coursesStaffLayer" style="opacity:0.3"></div>
  <div class="container" style="position:relative; z-index:1;">
    <div class="section-header text-center">
      <span class="section-tag gsap-reveal">Our Courses</span>
      <h2 class="section-title gsap-reveal">Explore Our <span class="text-gradient">Programs</span></h2>
      <p class="section-subtitle gsap-reveal">Comprehensive music and dance programs designed to nurture your artistic growth at every level.</p>
    </div>

    <h3 class="subsection-label gsap-reveal"><i class="fa-solid fa-music me-2"></i>Featured Classes</h3>

    <div class="row g-4 courses-grid">
      <% courses.forEach((course, i) => { %>
      <div class="col-sm-6 col-lg-3 gsap-card" data-index="<%= i %>">
        <div class="course-card" style="--card-color: <%= course.color %>">
          <div class="course-card-glow"></div>
          <div class="course-card-img-wrap">
            <img src="<%= course.image %>" alt="<%= course.title %>" class="course-card-img" loading="lazy"
                 onerror="this.style.display='none'"/>
          </div>
          <div class="course-icon-wrap">
            <i class="fa-solid <%= course.icon %>"></i>
          </div>
          <h4 class="course-title"><%= course.title %></h4>
          <p class="course-by">By <%= course.instructor %></p>
          <p class="course-desc"><%= course.desc %></p>
          <div class="course-footer">
            <span class="course-price">From <%= course.price %>/–</span>
            <a href="/courses" class="btn-course-learn">Learn More <i class="fa-solid fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="text-center mt-5 gsap-reveal">
      <a href="/courses" class="btn btn-primary-trs btn-magnetic">
        <i class="fa-solid fa-grip me-2"></i> View All 12 Courses
      </a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     INSTRUCTORS SECTION — 4 Teachers
═══════════════════════════════════════════════ -->
<section class="trs-section instructors-section" id="instructors" style="background:#F8F8F8; position:relative; overflow:hidden;">
  <div class="staff-layer" id="instructorsStaffLayer" style="opacity:0.2"></div>
  <div class="container" style="position:relative; z-index:1;">
    <div class="section-header text-center">
      <span class="section-tag gsap-reveal">The Team</span>
      <h2 class="section-title gsap-reveal">Meet Our <span class="text-gradient">Instructors</span></h2>
      <p class="section-subtitle gsap-reveal">World-class educators who bring passion, expertise, and inspiration to every lesson.</p>
    </div>

    <div class="row g-4 justify-content-center">
      <!-- Rounak Sir -->
      <div class="col-sm-6 col-lg-3 gsap-instructor" data-dir="left">
        <div class="instructor-card">
          <div class="instructor-photo-frame">
            <div class="instructor-photo-inner">
              <img src="/images/bprounak.PNG" alt="Rounak Sir" class="instructor-photo"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"/>
              <div class="instructor-photo-initial">R</div>
            </div>
            <div class="instructor-photo-ring"></div>
          </div>
          <h3 class="instructor-name">Rounak Singh</h3>
          <div class="instructor-tags">
            <span class="itag">Singing</span>
            <span class="itag">Guitar</span>
            <span class="itag">Piano</span>
          </div>
          <div class="instructor-exp">
            <i class="fa-solid fa-award"></i>12+ Years Experience
          </div>
          <p class="instructor-bio">Classical excellence and contemporary innovation in every lesson. Founder of The Raw Studios and touring musician.</p>
          <a href="/contact" class="btn btn-book-lesson btn-magnetic">
            <i class="fa-solid fa-calendar-plus me-2"></i>Book Lesson
          </a>
        </div>
      </div>

      <!-- Lakshay Sir -->
      <div class="col-sm-6 col-lg-3 gsap-instructor" data-dir="up">
        <div class="instructor-card">
          <div class="instructor-photo-frame">
            <div class="instructor-photo-inner">
              <img src="/images/laksh-sir.jpg" alt="Lakshay Sir" class="instructor-photo"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"/>
              <div class="instructor-photo-initial">L</div>
            </div>
            <div class="instructor-photo-ring"></div>
          </div>
          <h3 class="instructor-name">Lakshay</h3>
          <div class="instructor-tags">
            <span class="itag">Kathak</span>
            <span class="itag">Semi-Classical</span>
            <span class="itag">Bhangra</span>
          </div>
          <div class="instructor-exp">
            <i class="fa-solid fa-award"></i>8+ Years Experience
          </div>
          <p class="instructor-bio">From traditional Kathak to modern choreography — bringing fire, grace, and discipline to every performance.</p>
          <a href="/contact" class="btn btn-book-lesson btn-magnetic">
            <i class="fa-solid fa-calendar-plus me-2"></i>Book Lesson
          </a>
        </div>
      </div>

      <!-- Vedant Sir — TOP RATED -->
      <div class="col-sm-6 col-lg-3 gsap-instructor" data-dir="up">
        <div class="instructor-card featured-instructor">
          <div class="featured-badge"><i class="fa-solid fa-crown me-1"></i>Top Rated</div>
          <div class="instructor-photo-frame">
            <div class="instructor-photo-inner">
              <img src="/images/bpvedant.jpeg" alt="Vedant Sareen" class="instructor-photo"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"/>
              <div class="instructor-photo-initial">V</div>
            </div>
            <div class="instructor-photo-ring"></div>
          </div>
          <h3 class="instructor-name">Vedant</h3>
          <div class="instructor-tags">
            <span class="itag">Flute</span>
            <span class="itag">Sitar</span>
            <span class="itag">Violin</span>
          </div>
          <div class="instructor-exp">
            <i class="fa-solid fa-award"></i>7+ Years Experience
          </div>
          <p class="instructor-bio">Master of Indian and Western classical instruments. Brings deep musical knowledge to every guided session.</p>
          <a href="/contact" class="btn btn-book-lesson btn-magnetic">
            <i class="fa-solid fa-calendar-plus me-2"></i>Book Lesson
          </a>
        </div>
      </div>

      <!-- Monika Mam — NEW (Yoga Teacher) -->
      <div class="col-sm-6 col-lg-3 gsap-instructor" data-dir="right">
        <div class="instructor-card">
          <div class="new-badge"><i class="fa-solid fa-sparkles me-1"></i>New</div>
          <div class="instructor-photo-frame">
            <div class="instructor-photo-inner">
              <img src="/images/monaika-mam.jpg" alt="Monika Mam" class="instructor-photo"
                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"/>
              <div class="instructor-photo-initial">M</div>
            </div>
            <div class="instructor-photo-ring"></div>
          </div>
          <h3 class="instructor-name">Monika</h3>
          <div class="instructor-tags">
            <span class="itag">Yoga</span>
            <span class="itag">Wellness</span>
            <span class="itag">Mindfulness</span>
          </div>
          <div class="instructor-exp">
            <i class="fa-solid fa-award"></i>5+ Years Experience
          </div>
          <p class="instructor-bio">Certified yoga instructor bringing balance, mindfulness, and holistic wellness to students of all levels.</p>
          <a href="/contact" class="btn btn-book-lesson btn-magnetic">
            <i class="fa-solid fa-calendar-plus me-2"></i>Book Lesson
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

